# Copy to `.env` for local dev. Production values live in /etc/jesse/api.env on jesse-prod.

# Required (the app fails fast if app.db is imported without it). Once you've started
# Postgres locally, set one of:
# Docker:  postgresql+psycopg2://postgres:dev@localhost:5432/postgres
# Native:  postgresql+psycopg2:///jesse_dev
DATABASE_URL=

# Google OAuth 2.0 client (Web application). Create at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs to add in the Google console:
#   http://localhost:8000/v1/auth/google/callback   (local dev)
#   https://api.jesselab.space/v1/auth/google/callback   (prod)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Random string used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SESSION_SECRET=

# Where to send the browser after a successful Google callback if the
# `?next=` query param wasn't supplied or didn't match an allowed origin.
# Local dev typical: http://localhost:8001/
DEFAULT_POST_LOGIN_URL=/

# Comma-separated list of frontend origins. Used for both CORS allowlist
# (so PWAs can call the API with `credentials: 'include'`) and for the
# `?next=` redirect allowlist on /v1/auth/google/login.
# Local dev:  http://localhost:8001
# Prod:       https://training.jesselab.space,https://journal.jesselab.space,https://jesselab.space
ALLOWED_REDIRECT_ORIGINS=

# Set to .jesselab.space in prod so the session cookie is shared across
# subdomains (api.* sets it, training.* + journal.* read it).
# Leave empty in local dev (cookie defaults to host-only on localhost).
COOKIE_DOMAIN=

# `true` in prod (sets cookie Secure flag — TLS-only). `false` in local dev.
COOKIE_SECURE=false

LOG_LEVEL=INFO

# Anthropic API key used by the agent worker (jesse-agent-worker.service)
# to invoke Claude for skills like generate_plan. For now this is a single
# shared key — see TODO(BYOK) in app/agents/runner.py for the per-user plan.
ANTHROPIC_API_KEY=

# Telegram bot token from @BotFather. Used to fetch attached media via the
# Bot API and to reply with "got it" acks. Leave empty to disable the
# /v1/intake/telegram-webhook endpoint (returns 503).
TELEGRAM_BOT_TOKEN=

# Shared secret. Used as:
#   - bearer token for POST /v1/intake (any source)
#   - X-Telegram-Bot-Api-Secret-Token header for the Telegram webhook
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# Register the webhook (one-time):
#   curl "https://api.telegram.org/bot$TELEGRAM_BOT_TOKEN/setWebhook?url=https://api.jesselab.space/v1/intake/telegram-webhook&secret_token=$TELEGRAM_INTAKE_TOKEN"
TELEGRAM_INTAKE_TOKEN=

# users.id that all Telegram intake is attributed to. Single-user for V1.
TELEGRAM_OWNER_USER_ID=1
