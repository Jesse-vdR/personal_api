# Copy to `.env` for local dev. Production values live in /etc/jesse/api.env on jesse-prod.

# Required: bearer token for auth-protected endpoints (/v1/whoami, future /v1/training/*, etc.).
# Local dev: any string. Prod: long random string, never commit, store in password manager.
BEARER_TOKEN=dev-token-change-me

# Phase 3+. Leave blank until a real Postgres is running locally.
# Docker:  postgresql://postgres:dev@localhost:5432/postgres
# Native:  postgresql:///jesse_dev
DATABASE_URL=

LOG_LEVEL=INFO
