[Unit]
Description=Jesse personal API (FastAPI/uvicorn)
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/srv/jesse-api/repo
EnvironmentFile=-/etc/jesse/api.env
ExecStart=/srv/jesse-api/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000
Restart=on-failure
RestartSec=3
StandardOutput=journal
StandardError=journal
SyslogIdentifier=jesse-api

[Install]
WantedBy=multi-user.target
