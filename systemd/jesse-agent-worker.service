[Unit]
Description=Jesse personal API agent worker (Claude Agent SDK runner)
After=network.target postgresql.service
Wants=postgresql.service

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/srv/jesse-api/repo
EnvironmentFile=-/etc/jesse/api.env
ExecStart=/srv/jesse-api/venv/bin/python -m app.agents.worker
Restart=on-failure
RestartSec=5
StandardOutput=journal
StandardError=journal
SyslogIdentifier=jesse-agent-worker

[Install]
WantedBy=multi-user.target
